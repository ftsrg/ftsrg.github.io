 63w,\n/static/2226c126b41bb48e5eabcd46f0906008/2fd20/disc2019.png 125w,\n/static/2226c126b41bb48e5eabcd46f0906008/de391/disc2019.png 250w","sizes":"(min-width: 250px) 250px, 100vw"},"sources":[{"srcSet":"/static/2226c126b41bb48e5eabcd46f0906008/8287a/disc2019.avif 63w,\n/static/2226c126b41bb48e5eabcd46f0906008/3ebc4/disc2019.avif 125w,\n/static/2226c126b41bb48e5eabcd46f0906008/a9ff4/disc2019.avif 250w","type":"image/avif","sizes":"(min-width: 250px) 250px, 100vw"},{"srcSet":"/static/2226c126b41bb48e5eabcd46f0906008/74c72/disc2019.webp 63w,\n/static/2226c126b41bb48e5eabcd46f0906008/d66e1/disc2019.webp 125w,\n/static/2226c126b41bb48e5eabcd46f0906008/e7160/disc2019.webp 250w","type":"image/webp","sizes":"(min-width: 250px) 250px, 100vw"}]},"width":250,"height":250}}}}]},"locales":{"edges":[{"node":{"ns":"commons","data":"{\"commons.404.title\":\"404: Nem található az oldal\",\"commons.404.notFoundText\":\"A keresett oldal nem található a webhelyen...\",\"commons.ftsrgFullName\":\"Kritikus Rendszerek Kutatócsoport\",\"commons.ftsrgQuote\":\"„Átültetjük az elméletet a gyakorlatba”\",\"commons.readMore\":\"Bővebben\",\"commons.cookiePolicy.text\":\"Ez a weboldal sütiket használ a böngészési élmény növelése érdekében.\",\"commons.cookiePolicy.accept\":\"Megértettem\",\"commons.cookiePolicy.decline\":\"Elutasítom\",\"commons.cookiePolicy.socialBlocked\":\"A híreket közösségi média segítségével szolgáljuk ki. Engedélyezd a sütik használatát a megtekintésükhöz!\",\"commons.cookiePolicy.consentCookies\":\"Sütik engedélyezése\",\"footer.address.line1\":\"BME I épület, B szárny 4. emelet\",\"footer.address.line2\":\"Magyar tudósok körútja 2.\",\"footer.address.line3\":\"1117 Budapest, Magyarország\",\"footer.contactHero.haveQuestion\":\"Kérdésed van?\",\"footer.contactHero.askMe\":\"A kutatócsoporttal kapcsolatos kérdésekkel keresd <0>Dr. {{lastName}} {{firstName}}t</0>!\",\"footer.collabWithKirdev\":\"A weboldal a <1>Kir-Dev</1><0 />együttműködésével készült.\",\"footer.rightsAndSources\":\"Minden jog fenntartva | <0>Hozzájárulás kezelése</0> | Sablont a <1>Colorlib</1> biztosítja<2 />Fotók forrásai: <3>Hajdu Ákos</3>, <4>Pexels</4>, <5>Pixabay</5>, <6>SPOT</6> és <7>CERN</7>.\",\"meta.title\":\"ftsrg — Kritikus Rendszerek Kutatócsoport\",\"meta.titleTemplate\":\"%s | ftsrg — Kritikus Rendszerek Kutatócsoport\",\"meta.description\":\"A Kritikus Rendszerek Kutatócsoport célja olyan új módszerek és szoftverek kidolgozása, amiknek a segítségével a mérnökök jobb rendszereket készíthetnek.\",\"meta.keywords\":\"kutatás, rendszerek, analízis, verifikáció, modellezés\",\"nav.home.title\":\"Kezdőlap\",\"nav.home.shortTitle\":\"$t(nav.home.title)\",\"nav.home.competences\":\"Szakmai kompetenciáink\",\"nav.home.education\":\"Oktatás és tehetséggondozás\",\"nav.home.about\":\"A kutatócsoportról\",\"nav.home.projects\":\"Projektjeink\",\"nav.home.partners\":\"Partnereink\",\"nav.home.news\":\"Hírek\",\"nav.research.title\":\"Kutatás-fejlesztés\",\"nav.research.shortTitle\":\"Kutatás\",\"nav.research.projects\":\"K+F+I projektjeink\",\"nav.research.publications\":\"Publikációink\",\"nav.research.tools\":\"Eszközeink\",\"nav.research.events\":\"Események és díjak\",\"nav.education.title\":\"Oktatás\",\"nav.education.shortTitle\":\"$t(nav.education.title)\",\"nav.education.specializations\":\"Specializációk\",\"nav.education.courses\":\"Tantárgyaink\",\"nav.education.studentwork\":\"Önálló munka\",\"nav.education.talentcare\":\"Tehetséggondozás\",\"nav.education.achievements\":\"Hallgatóink eredményei\",\"nav.about.title\":\"Rólunk\",\"nav.about.shortTitle\":\"$t(nav.about.title)\",\"nav.about.about\":\"$t(nav.home.about)\",\"nav.about.members\":\"A kutatócsoport tagjai\",\"nav.about.formermembers\":\"Korábbi munkatársaink\",\"nav.about.students\":\"Hallgatóink\",\"nav.contact.title\":\"Kapcsolat\",\"nav.contact.shortTitle\":\"$t(nav.contact.title)\"}","language":"hu"}},{"node":{"ns":"research","data":"{\"research.heroTitle\":\"$t(nav.research.title)\",\"research.heroDesc\":\"Út az alap és alkalmazott kutatáson át az innovációig\",\"research.projects.title\":\"$t(nav.research.projects)\",\"research.events.title\":\"$t(nav.research.events)\",\"research.publications.title\":\"$t(nav.research.publications)\",\"research.tools.title\":\"$t(nav.research.tools)\",\"research.projects.description\":\"A kutatócsoport az elmúlt 25 évben több mint húsz nagy EU-s kutatási projektben (FP4-H2020) és 25-nél is több közvetlen ipari együttműködésben vett részt. Kutatás-fejlesztési projektjeinkben olyan új, innovatív szoftveralapú megoldásokat hozunk létre, amelyek jelentősen megkönnyítik a mérnökök munkáját.\",\"research.projects.counter1.title\":\"EU-s kutatási projekt\",\"research.projects.counter2.title\":\"Ipari együttműködés\",\"research.projects.counter3.title\":\"Hazai és bilaterális projekt\",\"research.publications.fullPubList\":\"Teljes publikációs lista\",\"research.publications.dataSets\":\"Adathalmazok\",\"research.publications.slides\":\"Diasorok\",\"research.publications.description\":\"Kutatócsoportunk rendszeresen publikál a szoftvertechnológia (TSE, IST, STTT), modellalapú fejlesztés (MODELS, SoSyM), a formális verifikáció (TACAS, JAR) és a szoftvertesztelés (ICST, STVR) vezető konferenciáin és folyóirataiban.\",\"research.tools.tool1.title\":\"A Gamma állapotgép-kompozíciós keretrendszer\",\"research.tools.tool1.desc\":\"A Gamma modellezőeszköz reaktív rendszerek komponensalapú tervezését, formális ellenőrzését, illetve implementációjának automatikus előállítását teszi lehetővé.\",\"research.tools.tool2.title\":\"A Theta modellellenőrző keretrendszer\",\"research.tools.tool2.desc\":\"A Theta modellellenőrző keretrendszer absztrakció-finomítás alapú, korszerű algoritmusok kollekciója, amelyek kombinálhatóságuk révén mindig az adott problémához szabhatók.\",\"research.tools.tool3.title\":\"A VIATRA Solver gráfgenerátor keretrendszer\",\"research.tools.tool3.desc\":\"A VIATRA Solver egy keretrendszer, amely szakterület-specifikus nyelvek jólformált és változatos példánymodelljeinek automatikus és skálázódó generálására szolgál.\",\"research.publications.autoGenGraphModel\":\"Olyan módszereket javasoltunk, amivel gráfok generálása során adott célfüggvény szerinti optimalizációs problémákat tudunk megoldani.\",\"research.publications.autoIsoWhitebox\":\"Olyan módszert és eszközt készítettünk, ami forráskód-alapú tesztgenerálás során a tesztelt modul izolációja érdekében automatikusan mock környezeteket generál.\",\"research.publications.faultInjectBlockchain\":\"A Coimbrai Egyetem kutatóival együttműködve olyan módszert javasoltunk, amivel blockchain rendszerek megbízhatósága vizsgálható.\",\"research.publications.stratForCEGAR\":\"Hatékony algoritmusokat javasoltunk a CEGAR-alapú modellellenőrzés továbbfejlesztéséhez, amik beágyazott szoftver és PLC kódok ellenőrzését segítik.\",\"research.projects.ADVANCE\":\"A BME részvételével 2019 januárjában elindult az „Addressing Verification and Validation Challenges in Future Cyber-Physical Systems” (ADVANCE) nevű H2020 RISE kutatási projekt, ami a jövő kiberfizikai rendszereinek ellenőrzési kihívásait fogja vizsgálni. A projekt futamideje 4 év és teljes költségvetése € 657 800.\",\"research.projects.arrowheadtools\":\"A BME TMIT és MIT részvételével 2019 májusában elindult az „Arrowhead Tools” H2020 ECSEL projekt, ami Európa legnagyobb, ipari digitalizációs és automatizálási megoldásokat fejlesztő K+F+I projektje. A projektben több mint 80 partner vesz részt, köztük az AITIA, evopro Innovation és az IncQuery Labs.\",\"research.projects.blockchain\":\"Az EIT Digital Professional School keretében kidolgozunk egy olyan tanfolyamsorozatot, ami bemutatja, hogy hogyan lehet a blockchain technológiákat beépíteni egy cég üzletmenetébe és innovatív szolgáltatásaiba.\",\"research.projects.EMBrACE\":\"A BME részvételével elindult az „Environment for model-based rigorous adaptive co-design and operation of CPS” (EMBrACE) című ITEA 3 projekt. Az IncQuery Labs és további húsz partner együttműködésével készítünk komplex ipari rendszerek tervezéséhez innovatív mérnöki nyelveket és eszközöket.\",\"research.projects.allPrevious.title\":\"Korábbi projektjeink\",\"research.projects.allPrevious.subtitle\":\"FP4-től H2020-ig\",\"research.projects.allPrevious.desc\":\"EU keretprogramok (EEMCN, FUTEG, HIDE, DECOS, RESIST, Sensoria, Deserec, Diana, Hidenets, SafeDMI, Amber, Genesys, Mogentes, SecureChange, E-freight, R3-COP, CECRIS, Concerto, MONDO, R5-COP...) és hazai kutatási pályázatok (MTA Lendület, ERC_HU, OTKA...)\",\"research.events.disc2019.title\":\"DISC 2019\",\"research.events.disc2019.subtitle\":\"33rd Int. Symposium on Distributed Computing\",\"research.events.disc2019.desc\":\"Kutatócsoportunk szervezte az International Symposium on Distributed Computing (DISC) konferenciát 2019. október 14-18. között Budapesten. A DISC egy nemzetközi, elismert akadémiai konferencia, aminek a témája az elosztott rendszerek és hálózatok elmélete, tervezése, analízise és alkalmazása.\",\"research.events.acadAwardPataricza.title\":\"Akadémiai Díj\",\"research.events.acadAwardPataricza.subtitle\":\"MTA Akadémiai Díj Pataricza András részére\",\"research.events.acadAwardPataricza.desc\":\"A díj elismerte a kritikus informatikai infrastruktúrák és a kiberfizikai rendszerek elméleti megalapozását, tervezését és fejlesztését célzó példaértékű munkásságát, a hibatűrés terén nemzetközileg is ismert iskolateremtő tudományos tevékenységét, valamint a tudományos utánpótlás nevelésében elért eredményeit.\",\"research.events.models2020.title\":\"MODELS Most influential paper\",\"research.events.models2020.subtitle\":\"Legnagyobb hatású cikk a MODELS 2020 konferencián\",\"research.events.models2020.desc\":\"Kutatócsoportunk jelenlegi és korábbi munkatársai vehették át a „Legnagyobb hatású cikk” díját a modellalapú rendszer- és szoftvertervezés legrangosabb nemzetközi tudományos fórumán az „Incremental Evaluation of Model Queries over EMF Models” című, a MODELS 2010 konferencián bemutatott publikációjukért.\",\"research.events.sosym2021.title\":\"SoSyM Most influential paper\",\"research.events.sosym2021.subtitle\":\"Legnagyobb hatású cikk a SoSyM folyóiratban\",\"research.events.sosym2021.desc\":\"Micskei Zoltán és Hélène Waeselynck vehették át a „Legnagyobb hatású cikk” díjat a Software and Systems Modeling, a modellalapú rendszer- és szoftvertervezés legrangosabb nemzetközi tudományos folyóiratában 10 évvel ezelőtt megjelent „The many meanings of UML 2 Sequence Diagrams: a survey” című publikációjukért.\",\"research.events.fka2022.title\":\"Fiatal Kutatók Akadémiája\",\"research.events.fka2022.subtitle\":\"Micskei Zoltán FKA tag lett\",\"research.events.fka2022.desc\":\"A Fiatal Kutatók Akadémiája 2022-ben tagjai közé választotta Micskei Zoltánt. Az Akadémia minden évben 12 új tagot választ a 40 év alatti kiemelkedő eredményt elért kutatók közül eddig tudományos teljesítményük és a fiatal kutatókat segítő terveiket bemutató pályázatuk alapján.\",\"research.events.mta2022.title\":\"Akadémiai Ifjúsági Díj\",\"research.events.mta2022.subtitle\":\"Akadémiai Ifjúsági Díj Semeráth Oszkár részére\",\"research.events.mta2022.desc\":\"A Magyar Tudományos Akadémia (MTA) 2021-ben Akadémiai Ifjúsági Díjban részesítette Semeráth Oszkárt az „Autonóm járművek ellenőrzése gráfalapú következtetéssel” című pályamunkájáért. A díjat 35 év alatti fiatalokat kaphatják kiemelkedő tudományos eredményeik elismerésére.\"}","language":"hu"}}]},"researchHero":{"childImageSharp":{"gatsbyImageData":{"layout":"fullWidth","placeholder":{"fallback":"data:image/jpeg;base64,"},"images":{"fallback":{"src":"/static/645210cb77cdd7dce35417d91107f03b/33355/bg_5.jpg","srcSet":"/static/645210cb77cdd7dce35417d91107f03b/19e5a/bg_5.jpg 750w,\n/static/645210cb77cdd7dce35417d91107f03b/5c354/bg_5.jpg 1080w,\n/static/645210cb77cdd7dce35417d91107f03b/c7a30/bg_5.jpg 1366w,\n/static/645210cb77cdd7dce35417d91107f03b/33355/bg_5.jpg 1920w","sizes":"1